<Window x:Class="Scratchdeck.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        mc:Ignorable="d"
        Title="Scratchdeck Hybrid"
        Width="860" Height="480"
        MinWidth="760" MinHeight="280"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        WindowStartupLocation="Manual"
        FontFamily="{DynamicResource UiFont}"
        FontSize="{DynamicResource AppFontSize}"
        Background="{DynamicResource WindowBackgroundBrush}"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp"
        PreviewMouseUp="Window_PreviewMouseUp"
        PreviewStylusUp="Window_PreviewStylusUp"
        Deactivated="Window_Deactivated"
        SourceInitialized="Window_SourceInitialized"
        Closing="Window_Closing"
        Closed="Window_Closed"
        LocationChanged="Window_PlacementChanged"
        SizeChanged="Window_PlacementChanged"
        StateChanged="Window_StateChanged">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="38"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <DataTemplate x:Key="ThemeColorFieldTemplate">
            <Grid Margin="0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="128" />
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center"
                           FontSize="{DynamicResource AppFontSize}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           Text="{Binding Label}" />
                <Border x:Name="Swatch"
                        Grid.Column="1"
                        Width="20" Height="20"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        Background="{Binding PreviewBrush}" />
                <TextBox x:Name="HexValue"
                         Grid.Column="2"
                         Height="25"
                         Padding="6,2"
                         FontFamily="{DynamicResource UiFont}"
                         Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsValid}" Value="False">
                    <Setter TargetName="HexValue" Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                    <Setter TargetName="Swatch" Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource WindowFrameBrush}"
            BorderThickness="1"
            Background="{DynamicResource WindowBackgroundBrush}"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="FolderPanelColumn"
                                  Width="176"
                                  MinWidth="132"
                                  MaxWidth="300" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="38" />
                <RowDefinition Height="39" />
                <RowDefinition Height="33" />
                <RowDefinition Height="*" />
                <RowDefinition Height="24" />
            </Grid.RowDefinitions>

            <!-- Custom title bar -->
            <Grid Grid.Row="0"
                  Grid.ColumnSpan="3"
                  Background="{DynamicResource SurfaceBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Border Width="22" Height="22"
                            BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="1"
                            Background="{DynamicResource AccentMutedBrush}">
                        <Path Width="9" Height="15"
                              Stretch="Fill"
                              Fill="{DynamicResource SecondaryAccentBrush}"
                              Data="M7,0 L1,8 L5,8 L3,15 L10,6 L6,6 Z" />
                    </Border>
                    <TextBlock Margin="9,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="{DynamicResource AppFontSize}"
                               FontWeight="SemiBold"
                               Text="SCRATCHDECK HYBRID" />
                    <Border Width="1" Height="13" Margin="10,0"
                            Background="{DynamicResource BorderBrush}" />
                    <TextBlock VerticalAlignment="Center"
                               FontSize="{DynamicResource AppFontSize}"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               Text="RAPID CAPTURE / LOCAL" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <ToggleButton x:Name="WrapToggle"
                                  Width="50" Height="38"
                                  Style="{StaticResource AccentEdgeToggleStyle}"
                                  ToolTip="Wrap long lines inside the editor"
                                  Checked="WrapToggle_Changed"
                                  Unchecked="WrapToggle_Changed">
                        <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                   Text="WRAP" />
                    </ToggleButton>
                    <ToggleButton x:Name="PinToggle"
                                  Width="44" Height="38"
                                  Style="{StaticResource AccentEdgeToggleStyle}"
                                  ToolTip="Always on top (Ctrl+Shift+P)"
                                  Checked="PinToggle_Changed"
                                  Unchecked="PinToggle_Changed">
                        <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                   Text="PIN" />
                    </ToggleButton>
                    <Button Style="{StaticResource WindowButtonStyle}"
                            ToolTip="Minimise"
                            Click="MinimiseButton_Click"
                            Content="─" />
                    <Button x:Name="MaximiseButton"
                            Style="{StaticResource WindowButtonStyle}"
                            ToolTip="Maximise or restore"
                            Click="MaximiseButton_Click"
                            Content="□" />
                    <Button Style="{StaticResource CloseWindowButtonStyle}"
                            ToolTip="Close"
                            Click="CloseButton_Click"
                            Content="×" />
                </StackPanel>
            </Grid>

            <!-- Folder/category sidebar -->
            <Border Grid.Row="1"
                    Grid.RowSpan="4"
                    Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="39" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="24" />
                    </Grid.RowDefinitions>

                    <Grid Background="{DynamicResource SurfaceRaisedBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="38" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Margin="11,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="{DynamicResource AppFontSize}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Text="FOLDERS" />
                        <Button x:Name="AddFolderButton"
                                Grid.Column="1"
                                Padding="0"
                                Style="{StaticResource PlusTabButtonStyle}"
                                BorderThickness="1,0,0,1"
                                FontSize="18"
                                FontWeight="Light"
                                ToolTip="Add folder"
                                Click="AddFolderButton_Click"
                                Content="+" />
                    </Grid>

                    <ListBox x:Name="FolderList"
                             Grid.Row="1"
                             ItemsSource="{Binding Folders}"
                             ItemContainerStyle="{StaticResource TabContainerStyle}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             AllowDrop="True"
                             SelectionChanged="FolderList_SelectionChanged"
                             PreviewMouseLeftButtonDown="FolderList_PreviewMouseLeftButtonDown"
                             PreviewMouseMove="FolderList_PreviewMouseMove"
                             Drop="FolderList_Drop">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="36"
                                      PreviewMouseLeftButtonDown="FolderRow_PreviewMouseLeftButtonDown">
                                    <Grid.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="Rename folder"
                                                      Click="RenameFolderMenuItem_Click" />
                                            <MenuItem Header="Remove folder"
                                                      Click="RemoveFolderMenuItem_Click" />
                                        </ContextMenu>
                                    </Grid.ContextMenu>

                                    <Border x:Name="FolderChrome"
                                            Margin="5,2"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="1" />
                                    <Path x:Name="FolderActiveCut"
                                          Width="7" Height="7"
                                          Margin="0,2,5,0"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Top"
                                          Fill="Transparent"
                                          Data="{StaticResource SelectedCornerGeometry}" />

                                    <Grid Margin="12,0,10,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="19" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Rectangle x:Name="FolderIcon"
                                                   Width="14" Height="14"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Fill="{DynamicResource MutedTextBrush}">
                                            <Rectangle.OpacityMask>
                                                <ImageBrush ImageSource="Assets/T_Folder.png"
                                                            Stretch="Uniform" />
                                            </Rectangle.OpacityMask>
                                        </Rectangle>

                                        <Grid Grid.Column="1" Margin="3,0,5,0">
                                            <TextBlock x:Name="FolderTitle"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       FontSize="{DynamicResource AppFontSize}"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       Text="{Binding Title}" />
                                            <TextBox x:Name="FolderRenameTextBox"
                                                     Height="25"
                                                     Padding="4,2"
                                                     VerticalAlignment="Center"
                                                     Visibility="Collapsed"
                                                     Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                                     LostKeyboardFocus="FolderRenameTextBox_LostKeyboardFocus"
                                                     KeyDown="FolderRenameTextBox_KeyDown" />
                                        </Grid>

                                        <TextBlock Grid.Column="2"
                                                   MinWidth="20"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"
                                                   FontFamily="{DynamicResource UiFont}"
                                                   FontSize="{DynamicResource AppFontSize}"
                                                   Foreground="{DynamicResource SubtleTextBrush}"
                                                   Text="{Binding Tabs.Count}" />
                                    </Grid>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                        <Setter TargetName="FolderTitle" Property="Visibility" Value="Collapsed" />
                                        <Setter TargetName="FolderRenameTextBox" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                        <Setter TargetName="FolderChrome" Property="Background" Value="{DynamicResource AccentMutedBrush}" />
                                        <Setter TargetName="FolderChrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                        <Setter TargetName="FolderActiveCut" Property="Fill" Value="{DynamicResource SecondaryAccentBrush}" />
                                        <Setter TargetName="FolderTitle" Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                        <Setter TargetName="FolderIcon" Property="Fill" Value="{DynamicResource AccentBrush}" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="2"
                               Margin="11,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="{DynamicResource AppFontSize}"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               Text="DRAG TO REORDER" />
                </Grid>
            </Border>

            <GridSplitter x:Name="FolderSplitter"
                          Grid.Row="1"
                          Grid.RowSpan="4"
                          Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="False"
                          DragCompleted="FolderSplitter_DragCompleted">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
                        <Setter Property="Opacity" Value="0.45" />
                        <Setter Property="Cursor" Value="SizeWE" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Opacity" Value="0.78" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SecondaryAccentBrush}" />
                                <Setter Property="Opacity" Value="0.9" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>

            <!-- Tabs -->
            <Grid Grid.Row="1"
                  Grid.Column="2"
                  Background="{DynamicResource SurfaceBrush}">
                <ListBox x:Name="TabsList"
                         ItemContainerStyle="{StaticResource TabContainerStyle}"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         AllowDrop="True"
                         SelectionChanged="TabsList_SelectionChanged"
                         PreviewMouseLeftButtonDown="TabsList_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="TabsList_PreviewMouseMove"
                         Drop="TabsList_Drop">
                    <ListBox.Template>
                        <ControlTemplate TargetType="ListBox">
                            <ScrollViewer x:Name="PART_ScrollViewer"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          CanContentScroll="False">
                                <StackPanel Orientation="Horizontal">
                                    <ItemsPresenter />
                                    <Button Width="42" Height="38"
                                            Style="{StaticResource PlusTabButtonStyle}"
                                            BorderThickness="0,0,1,1"
                                            ToolTip="New tab (Ctrl+T)"
                                            FontSize="20"
                                            FontWeight="Light"
                                            Click="NewTabButton_Click"
                                            Content="+" />
                                </StackPanel>
                            </ScrollViewer>
                        </ControlTemplate>
                    </ListBox.Template>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="38" MinWidth="112" MaxWidth="210"
                                  PreviewMouseLeftButtonDown="TabHeader_PreviewMouseLeftButtonDown">
                                <Border x:Name="TabChrome"
                                        Background="Transparent"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,0,1,1" />
                                <Border x:Name="ActiveLine"
                                        Height="2"
                                        VerticalAlignment="Bottom"
                                        Margin="10,0"
                                        Background="Transparent" />
                                <Path x:Name="ActiveCut"
                                      Width="8" Height="8"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Top"
                                      Fill="Transparent"
                                      Data="M0,0 L8,0 L8,8 Z" />

                                <Grid Margin="10,0,4,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="13" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="24" />
                                    </Grid.ColumnDefinitions>
                                    <Path x:Name="LockMark"
                                          Grid.Column="0"
                                          Width="8" Height="10"
                                          Stretch="Fill"
                                          Fill="{DynamicResource SecondaryAccentBrush}"
                                          Visibility="Collapsed"
                                          Data="M1,4 L1,9 L7,9 L7,4 Z M2,4 L2,2 C2,0.7 3,0 4,0 C5,0 6,0.7 6,2 L6,4 L5,4 L5,2 C5,1.4 4.6,1 4,1 C3.4,1 3,1.4 3,2 L3,4 Z" />

                                    <Grid Grid.Column="1" Margin="3,0,3,0">
                                            <TextBlock x:Name="TabTitle"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontSize="{DynamicResource AppFontSize}"
                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                   Text="{Binding Title}" />
                                        <TextBox x:Name="RenameTextBox"
                                                 VerticalAlignment="Center"
                                                 Height="25"
                                                 Padding="4,2"
                                                 Visibility="Collapsed"
                                                 Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                                 LostKeyboardFocus="RenameTextBox_LostKeyboardFocus"
                                                 KeyDown="RenameTextBox_KeyDown" />
                                    </Grid>

                                    <Button Grid.Column="2"
                                            Width="23" Height="23"
                                            Padding="0"
                                            Style="{StaticResource ToolButtonStyle}"
                                            ToolTip="Close tab (Ctrl+W)"
                                            Tag="{Binding}"
                                            Click="TabCloseButton_Click"
                                            Content="×" />
                                </Grid>
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsProtected}" Value="True">
                                    <Setter TargetName="LockMark" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                    <Setter TargetName="TabTitle" Property="Visibility" Value="Collapsed" />
                                    <Setter TargetName="RenameTextBox" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                    <Setter TargetName="TabChrome" Property="Background" Value="{DynamicResource AccentMutedBrush}" />
                                    <Setter TargetName="TabChrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                    <Setter TargetName="ActiveLine" Property="Background" Value="{DynamicResource AccentBrush}" />
                                    <Setter TargetName="ActiveCut" Property="Fill" Value="{DynamicResource SecondaryAccentBrush}" />
                                    <Setter TargetName="TabTitle" Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- Compact per-tab controls -->
            <Grid Grid.Row="2"
                  Grid.Column="2"
                  Background="{DynamicResource SurfaceRaisedBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel x:Name="TextToolsPanel"
                            Grid.Column="0"
                            Orientation="Horizontal"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center"
                               Margin="0,0,7,0"
                               FontSize="{DynamicResource AppFontSize}"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               Text="MODE" />
                    <ComboBox x:Name="SyntaxCombo"
                              Width="100"
                              SelectionChanged="SyntaxCombo_SelectionChanged" />
                    <Border Width="1" Height="17" Margin="5,0"
                            Background="{DynamicResource BorderBrush}" />
                    <ToggleButton x:Name="LineNumbersToggle"
                                  Style="{StaticResource AccentEdgeToggleStyle}"
                                  Padding="6,4"
                                  ToolTip="Show line numbers"
                                  Checked="LineNumbersToggle_Changed"
                                  Unchecked="LineNumbersToggle_Changed">
                        <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                   Text="LINES" />
                    </ToggleButton>
                    <ToggleButton x:Name="ProtectedToggle"
                                  Margin="3,0,0,0"
                                  Style="{StaticResource SecondaryToggleStyle}"
                                  Padding="6,4"
                                  ToolTip="Encrypt both text and scratch data for this tab with Windows DPAPI."
                                  Checked="ProtectedToggle_Changed"
                                  Unchecked="ProtectedToggle_Changed">
                        <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                   Text="LOCK" />
                    </ToggleButton>
                </StackPanel>

                <StackPanel x:Name="ScratchToolsPanel"
                            Grid.Column="0"
                            Orientation="Horizontal"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock VerticalAlignment="Center"
                               Margin="0,0,5,0"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               Text="SIZE" />
                    <ComboBox x:Name="ScratchBrushSizeCombo"
                              Width="48"
                              ToolTip="Brush and Shift-eraser size"
                              SelectionChanged="ScratchBrushSizeCombo_SelectionChanged" />
                    <Button x:Name="ScratchColorButton"
                            Width="32" Height="27"
                            Margin="5,0,0,0"
                            Padding="4"
                            Style="{StaticResource ToolButtonStyle}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            ToolTip="Choose brush color"
                            Click="ScratchColorButton_Click">
                        <Border x:Name="ScratchColorSwatch"
                                Width="18" Height="13"
                                BorderBrush="{DynamicResource TextBrush}"
                                BorderThickness="1"
                                Background="{DynamicResource AccentBrush}" />
                    </Button>
                    <Button Width="48"
                            Height="27"
                            Margin="5,0,0,0"
                            Padding="3,4"
                            Style="{StaticResource ToolButtonStyle}"
                            Foreground="{DynamicResource SecondaryAccentBrush}"
                            BorderBrush="{DynamicResource SecondaryAccentBrush}"
                            BorderThickness="1"
                            ToolTip="Clear the scratch board (Ctrl+Z restores it)"
                            Click="ClearScratchButton_Click"
                            Content="CLEAR" />
                    <Popup x:Name="ScratchColorPopup"
                           PlacementTarget="{Binding ElementName=ScratchColorButton}"
                           Placement="Bottom"
                           HorizontalOffset="-115"
                           VerticalOffset="3"
                           AllowsTransparency="True"
                           StaysOpen="False"
                           PopupAnimation="Fade">
                        <Border Width="226"
                                Padding="12"
                                Background="{DynamicResource SurfaceRaisedBrush}"
                                BorderBrush="{DynamicResource WindowFrameBrush}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,8"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}"
                                           Text="BRUSH COLORS" />
                                <ListBox x:Name="ScratchPaletteList"
                                         Width="150" Height="150"
                                         HorizontalAlignment="Left"
                                         SelectionChanged="ScratchPaletteList_SelectionChanged">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="5" Rows="5" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="SlotFrame"
                                                                Margin="1"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="1"
                                                                Background="{DynamicResource SurfaceBrush}">
                                                            <ContentPresenter />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="SlotFrame" Property="BorderBrush" Value="{DynamicResource SecondaryAccentBrush}" />
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="SlotFrame" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                                <Setter TargetName="SlotFrame" Property="BorderThickness" Value="2" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="2"
                                                    Background="{Binding PreviewBrush}"
                                                    ToolTip="{Binding Hex}" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBlock Margin="0,10,0,4"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           Text="CUSTOM HEX / REPLACE SLOT" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="ScratchHexColorBox"
                                             Height="27"
                                             Padding="6,3"
                                             Text="#19D9F0" />
                                    <Button Grid.Column="1"
                                            Margin="5,0,0,0"
                                            Padding="9,4"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Click="AddScratchColorButton_Click"
                                            Content="ADD" />
                                </Grid>
                                <TextBlock x:Name="ScratchColorError"
                                           MinHeight="14"
                                           Margin="0,4,0,0"
                                           Foreground="{DynamicResource DangerBrush}" />
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>

                <Border Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="TextSurfaceModeRadio"
                                     GroupName="TabSurfaceMode"
                                     Style="{StaticResource SegmentRadioStyle}"
                                     BorderThickness="0,0,1,0"
                                     Checked="TextSurfaceModeRadio_Checked">
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                       Text="TEXT" />
                        </RadioButton>
                        <RadioButton x:Name="ScratchSurfaceModeRadio"
                                     GroupName="TabSurfaceMode"
                                     Style="{StaticResource SegmentRadioStyle}"
                                     BorderThickness="0"
                                     Checked="ScratchSurfaceModeRadio_Checked">
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                       Text="SCRATCH" />
                        </RadioButton>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="2"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal"
                            Margin="0,0,9,0"
                            VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center"
                               Margin="0,0,7,0"
                               FontSize="{DynamicResource AppFontSize}"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               Text="APP" />
                    <ComboBox x:Name="AppThemeCombo"
                              Width="96"
                              DisplayMemberPath="Title"
                              SelectionChanged="AppThemeCombo_SelectionChanged" />
                    <TextBlock VerticalAlignment="Center"
                               Margin="8,0,7,0"
                               FontSize="{DynamicResource AppFontSize}"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               Text="CODE" />
                    <ComboBox x:Name="CodeThemeCombo"
                              Width="96"
                              DisplayMemberPath="Title"
                              SelectionChanged="CodeThemeCombo_SelectionChanged" />
                    <Button Width="36" Height="27"
                            Margin="4,0,0,0"
                            Padding="0"
                            Style="{StaticResource ToolButtonStyle}"
                            ToolTip="Open theme panel"
                            Click="OpenThemePanelButton_Click"
                            Content="EDIT" />
                </StackPanel>
            </Grid>

            <!-- Editor and in-editor search -->
            <Grid Grid.Row="3"
                  Grid.Column="2"
                  Background="{DynamicResource EditorBackgroundBrush}">
                <avalonEdit:TextEditor x:Name="Editor"
                                       Background="{DynamicResource EditorBackgroundBrush}"
                                       Foreground="{DynamicResource EditorForegroundBrush}"
                                       LineNumbersForeground="{DynamicResource EditorLineNumberBrush}"
                                       FontFamily="{DynamicResource CodeFont}"
                                       FontSize="{DynamicResource CodeFontSize}"
                                       Padding="8,7"
                                       ShowLineNumbers="True"
                                       WordWrap="False"
                                       HorizontalScrollBarVisibility="Auto"
                                       VerticalScrollBarVisibility="Auto"
                                       PreviewMouseWheel="Editor_PreviewMouseWheel"
                                       PreviewMouseRightButtonDown="Editor_PreviewMouseRightButtonDown"
                                       TextChanged="Editor_TextChanged">
                    <avalonEdit:TextEditor.Resources>
                        <Style TargetType="ScrollBar"
                               BasedOn="{StaticResource {x:Type ScrollBar}}">
                            <Setter Property="Background" Value="{DynamicResource EditorBackgroundBrush}" />
                        </Style>
                    </avalonEdit:TextEditor.Resources>
                    <avalonEdit:TextEditor.ContextMenu>
                        <ContextMenu x:Name="EditorContextMenu" Opened="EditorContextMenu_Opened">
                            <MenuItem x:Name="CutMenuItem"
                                      Header="Cut"
                                      InputGestureText="Ctrl+X"
                                      Click="CutMenuItem_Click" />
                            <MenuItem x:Name="CopyMenuItem"
                                      Header="Copy"
                                      InputGestureText="Ctrl+C"
                                      Click="CopyMenuItem_Click" />
                            <MenuItem x:Name="PasteMenuItem"
                                      Header="Paste"
                                      InputGestureText="Ctrl+V"
                                      Click="PasteMenuItem_Click" />
                            <Separator />
                            <MenuItem x:Name="SelectAllMenuItem"
                                      Header="Select All"
                                      InputGestureText="Ctrl+A"
                                      Click="SelectAllMenuItem_Click" />
                        </ContextMenu>
                    </avalonEdit:TextEditor.ContextMenu>
                </avalonEdit:TextEditor>

                <InkCanvas x:Name="ScratchCanvas"
                           Background="{DynamicResource EditorBackgroundBrush}"
                           ClipToBounds="True"
                           EditingMode="Ink"
                           UseCustomCursor="False"
                           Visibility="Collapsed"
                           PreviewMouseDown="ScratchCanvas_PreviewMouseDown"
                           PreviewStylusDown="ScratchCanvas_PreviewStylusDown"
                           LostMouseCapture="ScratchCanvas_LostMouseCapture"
                           LostStylusCapture="ScratchCanvas_LostStylusCapture"
                           StrokeCollected="ScratchCanvas_StrokeCollected"
                           StrokeErasing="ScratchCanvas_StrokeErasing"
                           StrokeErased="ScratchCanvas_StrokeErased" />

                <StackPanel x:Name="EmptyHint"
                            IsHitTestVisible="False"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Opacity="0.62">
                    <Path Width="26" Height="31"
                          Stretch="Fill"
                          HorizontalAlignment="Center"
                          Fill="{DynamicResource AccentMutedBrush}"
                          Stroke="{DynamicResource AccentBrush}"
                          StrokeThickness="1"
                          Data="M16,0 L2,17 L11,17 L7,31 L24,12 L15,12 Z" />
                    <TextBlock Margin="0,14,0,0"
                               HorizontalAlignment="Center"
                               FontFamily="{DynamicResource UiFont}"
                               FontSize="{DynamicResource AppFontSize}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="PASTE. TYPE. RETRIEVE." />
                    <TextBlock Margin="0,4,0,0"
                               HorizontalAlignment="Center"
                               FontSize="{DynamicResource AppFontSize}"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               Text="YOUR WORKSPACE SAVES ITSELF" />
                </StackPanel>

                <Border x:Name="SearchPanel"
                        Width="300" Height="35"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,9,12,0"
                        Background="{DynamicResource SurfaceRaisedBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="1"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="26" />
                            <ColumnDefinition Width="26" />
                            <ColumnDefinition Width="27" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SearchBox"
                                 Height="33"
                                 BorderThickness="0"
                                 FontFamily="{DynamicResource UiFont}"
                                 VerticalContentAlignment="Center"
                                 TextChanged="SearchBox_TextChanged"
                                 KeyDown="SearchBox_KeyDown" />
                        <TextBlock x:Name="SearchFeedback"
                                   Grid.Column="1"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   FontSize="{DynamicResource AppFontSize}"
                                   Foreground="{DynamicResource SecondaryAccentBrush}" />
                        <Button Grid.Column="2" Padding="0"
                                Style="{StaticResource ToolButtonStyle}"
                                ToolTip="Previous match (Shift+Enter)"
                                Click="SearchPreviousButton_Click"
                                Content="↑" />
                        <Button Grid.Column="3" Padding="0"
                                Style="{StaticResource ToolButtonStyle}"
                                ToolTip="Next match (Enter)"
                                Click="SearchNextButton_Click"
                                Content="↓" />
                        <Button Grid.Column="4" Padding="0"
                                Style="{StaticResource ToolButtonStyle}"
                                ToolTip="Close search (Escape)"
                                Click="SearchCloseButton_Click"
                                Content="×" />
                    </Grid>
                </Border>
            </Grid>

            <!-- Status strip -->
            <Grid Grid.Row="4"
                  Grid.Column="2"
                  Background="{DynamicResource SurfaceBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="CursorStatus"
                           Margin="11,0,0,0"
                           VerticalAlignment="Center"
                           FontFamily="{DynamicResource UiFont}"
                           FontSize="{DynamicResource AppFontSize}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           Text="LN 1  COL 1" />
                <TextBlock x:Name="CharacterStatus"
                           Grid.Column="1"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"
                           FontFamily="{DynamicResource UiFont}"
                           FontSize="{DynamicResource AppFontSize}"
                           Foreground="{DynamicResource SubtleTextBrush}"
                           Text="0 CHARS" />

                <TextBlock x:Name="ModeStatus"
                           Grid.Column="2"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontFamily="{DynamicResource UiFont}"
                           FontSize="{DynamicResource AppFontSize}"
                           Foreground="{DynamicResource SecondaryAccentBrush}" />

                <TextBlock x:Name="FontSizeStatus"
                           Grid.Column="2"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontFamily="{DynamicResource UiFont}"
                           FontSize="{DynamicResource AppFontSize}"
                           Foreground="{DynamicResource SecondaryAccentBrush}"
                           Visibility="Collapsed" />

                <TextBlock x:Name="ScratchHintStatus"
                           Grid.Column="0" Grid.ColumnSpan="3"
                           Margin="11,0,0,0"
                           VerticalAlignment="Center"
                           FontFamily="{DynamicResource UiFont}"
                           FontSize="{DynamicResource AppFontSize}"
                           Foreground="{DynamicResource SecondaryAccentBrush}"
                           Text="CTRL+Z  UNDO   •   HOLD SHIFT  BRUSH ERASE   •   HOLD ALT  STROKE ERASE"
                           Visibility="Collapsed" />

                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,11,0" VerticalAlignment="Center">
                    <Ellipse x:Name="SaveIndicator"
                             Width="6" Height="6"
                             Margin="0,0,6,0"
                             Fill="{DynamicResource SuccessBrush}" />
                    <TextBlock x:Name="SaveStatus"
                               FontFamily="{DynamicResource UiFont}"
                               FontSize="{DynamicResource AppFontSize}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="AUTOSAVED" />
                </StackPanel>
            </Grid>

            <!-- Theme catalog editor -->
            <Border x:Name="ThemePanelScrim"
                    Grid.Row="0" Grid.RowSpan="5"
                    Grid.Column="0" Grid.ColumnSpan="3"
                    Panel.ZIndex="90"
                    Background="{DynamicResource WindowBackgroundBrush}"
                    Opacity="0.72"
                    Visibility="Collapsed"
                    MouseLeftButtonDown="ThemePanelScrim_MouseLeftButtonDown" />

            <Border x:Name="ThemePanel"
                    Grid.Row="0" Grid.RowSpan="5"
                    Grid.Column="0" Grid.ColumnSpan="3"
                    Panel.ZIndex="100"
                    Width="420"
                    HorizontalAlignment="Right"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource WindowFrameBrush}"
                    BorderThickness="1,0,0,0"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="50" />
                    </Grid.RowDefinitions>

                    <Grid Background="{DynamicResource SurfaceRaisedBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="42" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontSize="{DynamicResource AppFontSize}" FontWeight="SemiBold" Text="THEME PANEL" />
                            <TextBlock Margin="9,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="{DynamicResource AppFontSize}"
                                       Foreground="{DynamicResource SecondaryAccentBrush}"
                                       Text="APP + CODE" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Style="{StaticResource WindowButtonStyle}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                                ToolTip="Close theme panel"
                                Click="CloseThemePanelButton_Click"
                                Content="×" />
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="14,12,16,16">
                            <TextBlock FontSize="{DynamicResource AppFontSize}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Text="APP THEME / CHROME" />
                            <TextBlock Margin="0,4,0,10"
                                       FontSize="{DynamicResource AppFontSize}"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       Text="Controls surfaces, accents, text, and the top-to-bottom outer-edge gradient." />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="74" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="AppThemeEditorCombo"
                                          DisplayMemberPath="Title"
                                          SelectionChanged="AppThemeEditorCombo_SelectionChanged" />
                                <Button Grid.Column="1"
                                        Margin="5,0,0,0"
                                        Style="{StaticResource ToolButtonStyle}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        Click="NewAppThemeButton_Click"
                                        Content="NEW" />
                            </Grid>
                            <TextBlock Margin="0,10,0,4"
                                       FontSize="{DynamicResource AppFontSize}"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       Text="TITLE" />
                            <TextBox x:Name="AppThemeTitleBox" />
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="128" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           Text="Font family" />
                                <TextBox x:Name="AppThemeFontFamilyBox"
                                         Grid.Column="1" Grid.ColumnSpan="2"
                                         Height="25" Padding="6,2" />
                                <TextBlock Grid.Row="1"
                                           Margin="0,6,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           Text="Font size" />
                                <TextBox x:Name="AppThemeFontSizeBox"
                                         Grid.Row="1" Grid.Column="1"
                                         Width="72" Height="25"
                                         Margin="0,6,0,0"
                                         HorizontalAlignment="Left"
                                         Padding="6,2" />
                                <TextBlock Grid.Row="1" Grid.Column="2"
                                           Margin="8,6,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           Text="8–16 pt" />
                            </Grid>
                            <ItemsControl x:Name="AppThemeFieldsList"
                                          Margin="0,7,0,0"
                                          ItemTemplate="{StaticResource ThemeColorFieldTemplate}" />

                            <Border Height="1" Margin="0,18,0,16"
                                    Background="{DynamicResource BorderBrush}" />

                            <TextBlock FontSize="{DynamicResource AppFontSize}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryAccentBrush}"
                                       Text="CODE THEME / EDITOR" />
                            <TextBlock Margin="0,4,0,10"
                                       FontSize="{DynamicResource AppFontSize}"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       Text="Controls editor background, foreground, selection, caret, line numbers, and syntax colors." />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="74" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="CodeThemeEditorCombo"
                                          DisplayMemberPath="Title"
                                          SelectionChanged="CodeThemeEditorCombo_SelectionChanged" />
                                <Button Grid.Column="1"
                                        Margin="5,0,0,0"
                                        Style="{StaticResource ToolButtonStyle}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        Click="NewCodeThemeButton_Click"
                                        Content="NEW" />
                            </Grid>
                            <TextBlock Margin="0,10,0,4"
                                       FontSize="{DynamicResource AppFontSize}"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       Text="TITLE" />
                            <TextBox x:Name="CodeThemeTitleBox" />
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="128" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           Text="Font family" />
                                <TextBox x:Name="CodeThemeFontFamilyBox"
                                         Grid.Column="1" Grid.ColumnSpan="2"
                                         Height="25" Padding="6,2" />
                                <TextBlock Grid.Row="1"
                                           Margin="0,6,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           Text="Font size" />
                                <TextBox x:Name="CodeThemeFontSizeBox"
                                         Grid.Row="1" Grid.Column="1"
                                         Width="72" Height="25"
                                         Margin="0,6,0,0"
                                         HorizontalAlignment="Left"
                                         Padding="6,2" />
                                <TextBlock Grid.Row="1" Grid.Column="2"
                                           Margin="8,6,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           Text="8–32 pt" />
                            </Grid>
                            <ItemsControl x:Name="CodeThemeFieldsList"
                                          Margin="0,7,0,0"
                                          ItemTemplate="{StaticResource ThemeColorFieldTemplate}" />
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="2"
                          Background="{DynamicResource SurfaceRaisedBrush}"
                          shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="76" />
                            <ColumnDefinition Width="76" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="12,0,6,0" VerticalAlignment="Center">
                            <TextBlock x:Name="ThemeEditorStatus"
                                       FontFamily="{DynamicResource UiFont}"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Text="READY" />
                            <TextBlock x:Name="ThemeFileStatus"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       Text="themes.json" />
                        </StackPanel>
                        <Button x:Name="ThemeCancelButton"
                                Grid.Column="1"
                                Margin="0,8,5,8"
                                Style="{StaticResource ToolButtonStyle}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                Click="CancelThemePanelButton_Click"
                                Content="CANCEL" />
                        <Button x:Name="ThemeSaveButton"
                                Grid.Column="2"
                                Margin="0,8,8,8"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="SaveThemePanelButton_Click"
                                Content="SAVE" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.ColumnSpan="3" Height="1" VerticalAlignment="Bottom"
                    Background="{DynamicResource BorderBrush}" IsHitTestVisible="False" />
            <Border Grid.Row="1" Grid.Column="2" Height="1" VerticalAlignment="Bottom"
                    Background="{DynamicResource AccentMutedBrush}" IsHitTestVisible="False" />
            <Border Grid.Row="2" Grid.Column="2" Height="1" VerticalAlignment="Bottom"
                    Background="{DynamicResource BorderBrush}" IsHitTestVisible="False" />
            <Border Grid.Row="4" Grid.Column="2" Height="1" VerticalAlignment="Top"
                    Background="{DynamicResource BorderBrush}" IsHitTestVisible="False" />
        </Grid>
    </Border>
</Window>
