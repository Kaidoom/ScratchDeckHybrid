<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#202630" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#252D38" />
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#2E3845" />
    <SolidColorBrush x:Key="BorderBrush" Color="#465365" />
    <LinearGradientBrush x:Key="WindowFrameBrush" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Offset="0" Color="#88C0D0" />
        <GradientStop Offset="1" Color="#B48EAD" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="AccentBrush" Color="#88C0D0" />
    <SolidColorBrush x:Key="AccentMutedBrush" Color="#88C0D0" Opacity="0.14" />
    <SolidColorBrush x:Key="SecondaryAccentBrush" Color="#B48EAD" />
    <SolidColorBrush x:Key="SecondaryAccentMutedBrush" Color="#B48EAD" Opacity="0.13" />
    <SolidColorBrush x:Key="TextBrush" Color="#ECEFF4" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#A5B0C0" />
    <SolidColorBrush x:Key="SubtleTextBrush" Color="#687589" />
    <SolidColorBrush x:Key="TabStripBrush" Color="#222934" />
    <SolidColorBrush x:Key="TabInactiveBackgroundBrush" Color="#323D4B" />
    <SolidColorBrush x:Key="TabInactiveBorderBrush" Color="#465365" />
    <SolidColorBrush x:Key="TabInactiveTextBrush" Color="#A5B0C0" />
    <SolidColorBrush x:Key="TabHoverBackgroundBrush" Color="#394856" />
    <SolidColorBrush x:Key="TabHoverBorderBrush" Color="#648495" />
    <SolidColorBrush x:Key="TabHoverTextBrush" Color="#ECEFF4" />
    <SolidColorBrush x:Key="TabActiveBackgroundBrush" Color="#445966" />
    <SolidColorBrush x:Key="TabActiveBorderBrush" Color="#749FB0" />
    <SolidColorBrush x:Key="TabActiveTextBrush" Color="#ECEFF4" />
    <SolidColorBrush x:Key="TabActiveEdgeBrush" Color="#88C0D0" />
    <SolidColorBrush x:Key="TabActiveDetailBrush" Color="#B48EAD" />
    <SolidColorBrush x:Key="TabCloseInactiveBrush" Color="#687589" />
    <SolidColorBrush x:Key="TabCloseHoverBrush" Color="#ECEFF4" />
    <SolidColorBrush x:Key="DangerBrush" Color="#BF616A" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#A3BE8C" />
    <SolidColorBrush x:Key="EditorBackgroundBrush" Color="#1D232C" />
    <SolidColorBrush x:Key="EditorForegroundBrush" Color="#E5E9F0" />
    <SolidColorBrush x:Key="EditorLineNumberBrush" Color="#687589" />
    <SolidColorBrush x:Key="EditorCaretBrush" Color="#ECEFF4" />
    <SolidColorBrush x:Key="SelectionBrush" Color="#3F5B72" />
    <SolidColorBrush x:Key="FocusBrush" Color="#88C0D0" />
    <SolidColorBrush x:Key="SyntaxCommentBrush" Color="#78869A" />
    <SolidColorBrush x:Key="SyntaxStringBrush" Color="#A3BE8C" />
    <SolidColorBrush x:Key="SyntaxKeywordBrush" Color="#B48EAD" />
    <SolidColorBrush x:Key="SyntaxNumberBrush" Color="#D08770" />
    <SolidColorBrush x:Key="SyntaxTypeBrush" Color="#88C0D0" />
</ResourceDictionary>
