<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#060910" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#0A1019" />
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#101925" />
    <SolidColorBrush x:Key="BorderBrush" Color="#253549" />
    <LinearGradientBrush x:Key="WindowFrameBrush" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Offset="0" Color="#19D9F0" />
        <GradientStop Offset="1" Color="#FFC247" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="AccentBrush" Color="#19D9F0" />
    <SolidColorBrush x:Key="AccentMutedBrush" Color="#19D9F0" Opacity="0.13" />
    <SolidColorBrush x:Key="SecondaryAccentBrush" Color="#FFC247" />
    <SolidColorBrush x:Key="SecondaryAccentMutedBrush" Color="#FFC247" Opacity="0.13" />
    <SolidColorBrush x:Key="TextBrush" Color="#EAF4F8" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#91A5B8" />
    <SolidColorBrush x:Key="SubtleTextBrush" Color="#586A7E" />
    <SolidColorBrush x:Key="TabStripBrush" Color="#080C14" />
    <SolidColorBrush x:Key="TabInactiveBackgroundBrush" Color="#10212D" />
    <SolidColorBrush x:Key="TabInactiveBorderBrush" Color="#253549" />
    <SolidColorBrush x:Key="TabInactiveTextBrush" Color="#91A5B8" />
    <SolidColorBrush x:Key="TabHoverBackgroundBrush" Color="#11303D" />
    <SolidColorBrush x:Key="TabHoverBorderBrush" Color="#207F94" />
    <SolidColorBrush x:Key="TabHoverTextBrush" Color="#EAF4F8" />
    <SolidColorBrush x:Key="TabActiveBackgroundBrush" Color="#124756" />
    <SolidColorBrush x:Key="TabActiveBorderBrush" Color="#1DA8BE" />
    <SolidColorBrush x:Key="TabActiveTextBrush" Color="#EAF4F8" />
    <SolidColorBrush x:Key="TabActiveEdgeBrush" Color="#19D9F0" />
    <SolidColorBrush x:Key="TabActiveDetailBrush" Color="#FFC247" />
    <SolidColorBrush x:Key="TabCloseInactiveBrush" Color="#586A7E" />
    <SolidColorBrush x:Key="TabCloseHoverBrush" Color="#EAF4F8" />
    <SolidColorBrush x:Key="DangerBrush" Color="#FF5B73" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#FFC247" />
    <SolidColorBrush x:Key="EditorBackgroundBrush" Color="#070C14" />
    <SolidColorBrush x:Key="EditorForegroundBrush" Color="#E4EBF0" />
    <SolidColorBrush x:Key="EditorLineNumberBrush" Color="#586A7E" />
    <SolidColorBrush x:Key="EditorCaretBrush" Color="#EAF4F8" />
    <SolidColorBrush x:Key="SelectionBrush" Color="#215C71" />
    <SolidColorBrush x:Key="FocusBrush" Color="#16DCE8" />
    <SolidColorBrush x:Key="SyntaxCommentBrush" Color="#68798E" />
    <SolidColorBrush x:Key="SyntaxStringBrush" Color="#E2D28A" />
    <SolidColorBrush x:Key="SyntaxKeywordBrush" Color="#50C9FF" />
    <SolidColorBrush x:Key="SyntaxNumberBrush" Color="#FFC247" />
    <SolidColorBrush x:Key="SyntaxTypeBrush" Color="#7AE7FF" />
</ResourceDictionary>
